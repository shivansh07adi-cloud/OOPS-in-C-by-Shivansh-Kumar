C++ code = 
#include<iostream>
using namespace std;

class Person{
public:
    string hair_color;
    float height;
    int weight;

    void Eat(){
        cout<<"Person is eating"<<endl;
    }

    void Sleep(){
        cout<<"Person is sleeping"<<endl;
    }

    void Run(){
        cout<<"Person is running"<<endl;
    }
};

int main()
{
    Person obj;

    obj.hair_color = "Black";
    obj.height = 5.10;
    obj.weight = 70;

    cout<<"Hair Color: "<<obj.hair_color<<endl;
    cout<<"Height: "<<obj.height<<" feet"<<endl;
    cout<<"Weight: "<<obj.weight<<" kg"<<endl;

    obj.Eat();
    obj.Sleep();
    obj.Run();

    return 0;
}




